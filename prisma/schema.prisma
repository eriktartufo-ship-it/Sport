datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Player {
  id        String        @id @default(uuid())
  name      String        @unique
  createdAt DateTime      @default(now())
  // Soft-delete: timestamp del momento di "cancellazione". Player con
  // deletedAt != null sono nascosti dalle liste attive (add player,
  // selettori nuova partita) ma la loro storia resta nei MatchResult
  // → continuano a comparire in classifica/cronologia/H2H.
  deletedAt DateTime?
  results   MatchResult[]
  // Riusati per il modulo 3vs3 (basket squadre): un Player può
  // partecipare a Match3v3 senza migration. Cascade come per MatchResult.
  results3v3 Match3v3Player[]
  // Riusati anche per Machiavelli (gioco di carte): stesso pattern.
  resultsMachiavelli MatchMachiavelliPlayer[]
}

model Sport {
  id                String             @id @default(uuid())
  name              String             @unique // e.g. "K.O.", "3v3", "Machiavelli"
  matches           Match[]
  matches3v3        Match3v3[]
  matchesMachiavelli MatchMachiavelli[]
}

model Match {
  id          String        @id @default(uuid())
  sport       Sport         @relation(fields: [sportId], references: [id])
  sportId     String
  date        DateTime      @default(now())
  playerCount Int
  results     MatchResult[]
}

model MatchResult {
  id       String @id @default(uuid())
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId  String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  playerId String
  medal    String // "GOLD", "SILVER", "BRONZE", "NONE"

  @@unique([matchId, playerId])
}

// 3vs3 basket: due squadre da 3 player ciascuna, score 0–21 FIBA.
// Vincitore sempre con 21 punti, perdente 0–20, no pareggio.
// La "squadra" come entità non esiste (set di 3 player è derivato dai
// Match3v3Player con teamSide). La classifica per combinazione aggrega
// in JS via SQL groupBy non efficiente su SQLite.
model Match3v3 {
  id         String           @id @default(uuid())
  sport      Sport            @relation(fields: [sportId], references: [id])
  sportId    String
  date       DateTime         @default(now())
  teamAScore Int
  teamBScore Int
  results    Match3v3Player[]
}

model Match3v3Player {
  id       String   @id @default(uuid())
  match    Match3v3 @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId  String
  player   Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  playerId String
  teamSide String // "A" oppure "B"

  @@unique([matchId, playerId])
}

// Machiavelli (gioco di carte): partita libera con 2+ giocatori.
// Si registra l'ORDINE di arrivo: chi finisce le carte per primo vince,
// chi resta con le carte in mano è ultimo. `position` = 1 per il vincitore,
// 2 per il secondo, ecc. I punti di partita = position - 1 (il vincitore
// fa 0 punti); in classifica generale vince chi ha meno punti.
model MatchMachiavelli {
  id      String                   @id @default(uuid())
  sport   Sport                    @relation(fields: [sportId], references: [id])
  sportId String
  date    DateTime                 @default(now())
  results MatchMachiavelliPlayer[]
}

model MatchMachiavelliPlayer {
  id       String           @id @default(uuid())
  match    MatchMachiavelli @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId  String
  player   Player           @relation(fields: [playerId], references: [id], onDelete: Cascade)
  playerId String
  position Int              @default(1) // 1 = vincitore; punti = position - 1

  @@unique([matchId, playerId])
}
