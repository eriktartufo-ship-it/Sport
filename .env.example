# Path al file SQLite (relativo alla cartella prisma/, perche' schema.prisma usa "file:./data/dev.db")
DATABASE_URL="file:./data/dev.db"

# Password admin per registrare partite/giocatori (CAMBIA IN PRODUZIONE)
ADMIN_PASSWORD="changeme"

# Segreto per firmare i JWT cookie. Genera con: openssl rand -base64 32
JWT_SECRET="supersecretjwtkey-change-me"

# --- Variabili usate SOLO da docker-compose ---

# Dominio pubblico servito da Traefik
APP_DOMAIN="sport.pieranlab.cloud"

# Nome della network Docker esterna dove vive Traefik (default: traefik-net)
TRAEFIK_NETWORK="traefik-net"

# Nome del certResolver Traefik configurato per Let's Encrypt
TRAEFIK_CERT_RESOLVER="letsencrypt"
